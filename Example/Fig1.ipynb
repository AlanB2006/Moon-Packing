      "source": [
        "import numpy as np\n",
        "import matplotlib.pyplot as plt\n",
        "from scipy.constants import astronomical_unit\n",
        "data = np.loadtxt('file.txt', delimiter=',', skiprows=1)\n",
        "\n",
        "time = data[:, 6]\n",
        "delta_H = data[:, 0]\n",
        "\n",
        "fig = plt.figure(figsize=(8, 4), dpi=150)\n",
        "ax = fig.add_subplot(111)\n",
        "ax.scatter(delta_H, time, s=5, color='black', label='Moon 1')\n",
        "\n",
        "ax.set_xlabel('Delta_H')\n",
        "ax.set_ylabel('Log t')\n",
        "\n",
        "ax.minorticks_on()\n",
        "ax.tick_params(which='both', direction='out', length=6, width=1, labelsize=12)\n",
        "ax.tick_params(which='minor', direction='out', length=3, width=1)\n",
        "\n",
        "ax.set_yscale('log')\n",
        "plt.show()\n"
      ],
      "outputs": [],
