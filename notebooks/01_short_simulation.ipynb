      "metadata": {},
      "outputs": [],
      "source": [
        "from moon_packing.simulation import SimulationConfig, run_simulation\n",
        "cfg = SimulationConfig('Luna', n_moons=2, tau_seconds=100, max_orbits=100)\n",
        "run_simulation(cfg, beta=7.2)\n"
      ]
